# Copy this file to `.env` and replace placeholders.
# Do not commit `.env` (it is listed in `.gitignore`).
#
# If the password contains URL-reserved characters (#, @, :, /, etc.),
# percent-encode them in the URL (e.g. `#` → `%23`).
#
# Format example:
# DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD_ENCODED@db.PROJECT_REF.supabase.co:5432/postgres

DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@db.PROJECT_REF.supabase.co:5432/postgres

# Optional: DEBUG, INFO, WARNING, ERROR, CRITICAL (default INFO)
# LOG_LEVEL=INFO
