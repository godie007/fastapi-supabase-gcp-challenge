# Copia este archivo a `.env` y reemplaza los valores.
# No subas `.env` al repositorio (ya está en `.gitignore`).
#
# Si tu contraseña tiene caracteres especiales (#, @, :, /, etc.),
# codifícalos en la URL (por ejemplo `#` → `%23`).
#
# Ejemplo de formato:
# DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD_ENCODED@db.PROJECT_REF.supabase.co:5432/postgres

DATABASE_URL=postgresql+psycopg2://postgres:CHANGE_ME@db.PROJECT_REF.supabase.co:5432/postgres
